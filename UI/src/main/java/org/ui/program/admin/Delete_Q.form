<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="org.ui.program.admin.Delete_Q">
  <grid id="27dc6" binding="panel" layout-manager="GridLayoutManager" row-count="4" column-count="3" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
    <margin top="5" left="5" bottom="5" right="5"/>
    <constraints>
      <xy x="20" y="20" width="645" height="247"/>
    </constraints>
    <properties/>
    <border type="none"/>
    <children>
      <component id="51675" class="javax.swing.JLabel" binding="welcome">
        <constraints>
          <grid row="0" column="0" row-span="1" col-span="2" vsize-policy="0" hsize-policy="0" anchor="0" fill="0" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <text value="Please provide information about question that ough to be deleted!"/>
        </properties>
      </component>
      <component id="516b" class="javax.swing.JLabel" binding="info">
        <constraints>
          <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="0" fill="0" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <text value="Please insert index or/and click the check box (on the right)"/>
        </properties>
      </component>
      <component id="e99ef" class="javax.swing.JTextField" binding="index_field">
        <constraints>
          <grid row="2" column="0" row-span="1" col-span="2" vsize-policy="0" hsize-policy="6" anchor="8" fill="1" indent="0" use-parent-layout="false">
            <minimum-size width="-1" height="25"/>
            <preferred-size width="150" height="25"/>
            <maximum-size width="-1" height="25"/>
          </grid>
        </constraints>
        <properties/>
      </component>
      <component id="e7783" class="javax.swing.JButton" binding="deleteButton">
        <constraints>
          <grid row="3" column="0" row-span="1" col-span="2" vsize-policy="2" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <text value="Delete"/>
        </properties>
      </component>
      <component id="c79cd" class="javax.swing.JButton" binding="closeButton">
        <constraints>
          <grid row="0" column="2" row-span="4" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <text value="Close"/>
        </properties>
      </component>
      <component id="f2944" class="javax.swing.JCheckBox" binding="all_questions_checkbox">
        <constraints>
          <grid row="1" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="4" fill="0" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <text value="Delete all questions"/>
        </properties>
      </component>
    </children>
  </grid>
</form>
