<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="org.ui.program.admin.Log_in">
  <grid id="27dc6" binding="panel" layout-manager="GridLayoutManager" row-count="5" column-count="2" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
    <margin top="5" left="5" bottom="5" right="5"/>
    <constraints>
      <xy x="20" y="20" width="641" height="272"/>
    </constraints>
    <properties/>
    <border type="none"/>
    <children>
      <component id="b61fb" class="javax.swing.JLabel" binding="login">
        <constraints>
          <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="0" fill="0" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <text value="Your login:"/>
        </properties>
      </component>
      <component id="cf291" class="javax.swing.JTextField" binding="loginField">
        <constraints>
          <grid row="2" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="6" anchor="8" fill="1" indent="0" use-parent-layout="false">
            <minimum-size width="-1" height="25"/>
            <preferred-size width="170" height="25"/>
            <maximum-size width="-1" height="25"/>
          </grid>
        </constraints>
        <properties/>
      </component>
      <component id="c282b" class="javax.swing.JLabel" binding="password">
        <constraints>
          <grid row="3" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="0" fill="0" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <text value="Your password:"/>
        </properties>
      </component>
      <component id="c72a1" class="javax.swing.JPasswordField" binding="passwordField">
        <constraints>
          <grid row="4" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="6" anchor="8" fill="1" indent="0" use-parent-layout="false">
            <minimum-size width="-1" height="25"/>
            <preferred-size width="170" height="25"/>
            <maximum-size width="-1" height="25"/>
          </grid>
        </constraints>
        <properties/>
      </component>
      <component id="e7497" class="javax.swing.JButton" binding="closeButton" default-binding="true">
        <constraints>
          <grid row="1" column="1" row-span="2" col-span="1" vsize-policy="0" hsize-policy="7" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <text value="Close"/>
        </properties>
      </component>
      <component id="dba0a" class="javax.swing.JButton" binding="logInButton" default-binding="true">
