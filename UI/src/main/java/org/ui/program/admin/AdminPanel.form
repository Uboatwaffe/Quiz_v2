<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="org.ui.program.admin.AdminPanel">
  <grid id="27dc6" binding="panel" layout-manager="GridLayoutManager" row-count="4" column-count="3" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
    <margin top="5" left="5" bottom="5" right="5"/>
    <constraints>
      <xy x="20" y="20" width="500" height="400"/>
    </constraints>
    <properties/>
    <border type="none"/>
    <children>
      <component id="24253" class="javax.swing.JLabel" binding="welcome">
        <constraints>
          <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="2" fill="0" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <text value="Welcome to the admin panel!"/>
        </properties>
      </component>
      <component id="437bf" class="javax.swing.JLabel" binding="what_to_do">
        <constraints>
          <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="1" fill="0" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <text value="What do you want to do?"/>
        </properties>
      </component>
      <component id="5107" class="javax.swing.JButton" binding="closeButton" default-binding="true">
        <constraints>
          <grid row="0" column="2" row-span="2" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <text value="Close"/>
        </properties>
      </component>
      <component id="e02b1" class="javax.swing.JButton" binding="showAnswersButton" default-binding="true">
        <constraints>
          <grid row="0" column="1" row-span="2" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <text value="Show answers"/>
        </properties>
      </component>
      <component id="6c0a3" class="javax.swing.JButton" binding="addQuestionButton" default-binding="true">
        <constraints>
          <grid row="2" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <text value="Add question"/>
        </properties>
      </component>
      <component id="704fb" class="javax.swing.JButton" binding="deleteQuestionButton" default-binding="true">
        <constraints>
          <grid row="3" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <text value="Delete question"/>
        </properties>
      </component>
      <component id="2f499" class="javax.swing.JButton" binding="showQuestionsButton" default-binding="true">
        <constraints>
          <grid row="2" column="1" row-span="2" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <text value="Show questions"/>
        </properties>
      </component>
      <component id="e9545" class="javax.swing.JButton" binding="othersButton" default-binding="true">
        <constraints>
          <grid row="2" column="2" row-span="2" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <text value="Others"/>
        </properties>
      </component>
    </children>
  </grid>
</form>
